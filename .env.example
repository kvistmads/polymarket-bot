# Polymarket Copy-Trading Bot — Environment Variables
# Kopiér denne fil til .env og udfyld værdierne
# .env må ALDRIG committes til git

# === Database ===
# Bruges af monitor.py og executor.py (asyncpg driver)
DB_URL=postgresql+asyncpg://bot:CHANGE_ME@localhost/polymarket
# Bruges af Docker Compose til at starte PostgreSQL-containeren
POSTGRES_PASSWORD=CHANGE_ME

# === Wallets ===
# Komma-separeret liste af Polymarket wallet-adresser der følges
FOLLOWED_WALLETS=0x...,0x...

# === Monitor ===
# Antal sekunder mellem poll-cycles
POLL_INTERVAL=30

# === Executor ===
# Polymarket L2 proxy wallet private key — ALDRIG commit denne til git!
POLYMARKET_PRIVATE_KEY=0x...
# Polymarket V2 deposit wallet adresse (smart contract wallet, ejes af din EOA).
# Deploy via polymarket.com frontend, find adressen i Settings.
# pUSD skal være i deposit wallet — IKKE i EOA — for at trades virker.
DEPOSIT_WALLET_ADDRESS=0x...
# Stop trading hvis daglig loss overstiger dette beløb i USD
MAX_DAILY_LOSS=50
# Andel af tilgængeligt cash per trade (0.05 = 5%)
POSITION_SIZE_PCT=0.05
# Minimum indgangspris — trades under denne grænse filtreres (Gate 9)
# Datastudie maj 2026: trades over 0.40 er profitable, under er negative
MIN_ENTRY_PRICE=0.40
# Paper trading mode — sæt til false KUN via Telegram go-live approval
DRY_RUN=true

# === Telegram ===
TELEGRAM_BOT_TOKEN=INDSÆT_NY_TOKEN_FRA_BOTFATHER
TELEGRAM_CHAT_ID=6204897951

# === Generelt ===
LOG_LEVEL=INFO

# === Dune Analytics (wallet-scanner) ===
# Hent gratis API-key på: https://dune.com/settings/api
# Opret query med SQL fra quick_scan.py og indsæt ID herunder
DUNE_API_KEY=
DUNE_QUERY_ID=

# === ECC ===
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=65
