# Polymarket Copy-Trading Bot — Environment Variables
# Kopiér denne fil til .env og udfyld værdierne
# .env må ALDRIG committes til git

# Database
DB_URL=postgresql+asyncpg://bot:SKIFT_MIG@localhost/polymarket
POSTGRES_PASSWORD=SKIFT_MIG

# Monitor
FOLLOWED_WALLETS=0xADRESSE1,0xADRESSE2
POLL_INTERVAL=30
LOG_LEVEL=INFO

# Telegram (opret bot via @BotFather)
TELEGRAM_BOT_TOKEN=DIT_BOT_TOKEN
TELEGRAM_CHAT_ID=DIT_CHAT_ID

# Executor
POLYMARKET_PRIVATE_KEY=DIN_PRIVATE_KEY_HER
MAX_DAILY_LOSS=50
POSITION_SIZE_PCT=0.05
DRY_RUN=true

# Claude Code
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=65
